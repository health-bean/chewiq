const SmartProtocolSelector = ({ selectedItems, onToggleItem, userProtocols = [] }) => {
  const [searchTerm, setSearchTerm] = useState('');
  const [showNewProtocolPrompt, setShowNewProtocolPrompt] = useState(false);
  const [availableProtocols, setAvailableProtocols] = useState([]);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    const loadProtocols = async () => {
      try {
        const response = await fetch(`${API_BASE_URL}/api/v1/protocols`);
        const data = await response.json();
        
        if (data.protocols) {
          const protocolNames = data.protocols.map(p => p.name);
          setAvailableProtocols(protocolNames);
        }
      } catch (error) {
        console.error('Failed to load protocols:', error);
        setAvailableProtocols(['Coffee Enema', 'Infrared Sauna', 'Epsom Salt Bath']);
      } finally {
        setLoading(false);
      }
    };

    loadProtocols();
  }, []);

  const allProtocols = [...new Set([...userProtocols, ...availableProtocols])];

  const getFilteredProtocols = () => {
    let protocols = allProtocols;
    
    if (searchTerm) {
      protocols = protocols.filter(protocol => 
        protocol.toLowerCase().includes(searchTerm.toLowerCase())
      );
      
      if (protocols.length === 0 || !protocols.some(protocol => protocol.toLowerCase() === searchTerm.toLowerCase())) {
        setShowNewProtocolPrompt(true);
      } else {
        setShowNewProtocolPrompt(false);
      }
    } else {
      setShowNewProtocolPrompt(false);
    }
    
    return protocols;
  };

  const addNewProtocol = () => {
    if (!searchTerm.trim()) return;
    
    setAvailableProtocols([...availableProtocols, searchTerm.trim()]);
    onToggleItem(searchTerm.trim());
    setSearchTerm('');
    setShowNewProtocolPrompt(false);
  };

  const filteredProtocols = getFilteredProtocols();

  if (loading) {
    return <div className="text-center py-4">Loading protocols...</div>;
  }

  return (
    <div className="space-y-4">
      <div className="relative">
        <Search size={16} className="absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400" />
        <input
          type="text"
          placeholder="Start typing to search protocols..."
          value={searchTerm}
          onChange={(e) => setSearchTerm(e.target.value)}
          className="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-transparent"
        />
      </div>

      {showNewProtocolPrompt && searchTerm.trim() && (
        <div className="p-3 border-2 border-dashed border-purple-300 rounded-lg bg-purple-50">
          <div className="flex items-center justify-between">
            <div>
              <p className="text-sm font-medium text-purple-800">
                "{searchTerm}" not found in your protocols
              </p>
              <p className="text-xs text-purple-600">Add it to your detox protocol list?</p>
            </div>
            <Button variant="primary" size="sm" onClick={addNewProtocol}>
              Add Protocol
            </Button>
          </div>
        </div>
      )}

      <div className="max-h-48 overflow-y-auto space-y-2">
        {filteredProtocols.map((protocol) => {
          const isSelected = selectedItems.includes(protocol);
          
          return (
            <div key={protocol} className={`p-3 border rounded-lg cursor-pointer transition-all ${
              isSelected 
                ? 'border-purple-500 bg-purple-50' 
                : 'border-gray-200 hover:border-gray-300'
            }`} onClick={() => onToggleItem(protocol)}>
              <div className="flex items-center space-x-2">
                <input
                  type="checkbox"
                  checked={isSelected}
                  onChange={() => onToggleItem(protocol)}
                  className="rounded text-purple-600 focus:ring-purple-500"
                />
                <span className="font-medium">{protocol}</span>
              </div>
            </div>
          );
        })}
      </div>
      
      {filteredProtocols.length === 0 && !showNewProtocolPrompt && (
        <div className="text-center py-8 text-gray-500">
          <p>No protocols found matching "{searchTerm}"</p>
          <p className="text-sm">Try a different search term</p>
        </div>
      )}
    </div>
  );
};

