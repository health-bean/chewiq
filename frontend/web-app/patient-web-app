const EnhancedDailyJournal = () => {
  const [selectedDate, setSelectedDate] = useState(new Date().toISOString().split('T')[0]);
  const [showAddEntry, setShowAddEntry] = useState(false);
  const [activeView, setActiveView] = useState('timeline');
  
  // Protocol Selection
  const [availableProtocols, setAvailableProtocols] = useState([]);
  const [selectedProtocolId, setSelectedProtocolId] = useState(null);
  const [loadingProtocols, setLoadingProtocols] = useState(true);
  
  // Entry state
  const [newEntry, setNewEntry] = useState({
    time: new Date().toTimeString().slice(0, 5),
    type: 'food',
    selectedItems: [],
    selectedFoods: [],
    customText: '',
    severities: {}
  });

  // State variables
  const [selectedDetoxProtocols, setSelectedDetoxProtocols] = useState([]);
  const [userDetoxProtocols, setUserDetoxProtocols] = useState([]);
  const [overallNotes, setOverallNotes] = useState('');
  const [detoxOtherActivities, setDetoxOtherActivities] = useState('');
  const [mindfulnessActivities, setMindfulnessActivities] = useState('');

  // Load real data from APIs
  const [dailyEntries, setDailyEntries] = useState([]);
  const [loadingEntries, setLoadingEntries] = useState(true);

  // Load protocols on component mount
  useEffect(() => {
    const loadProtocols = async () => {
      try {
        const response = await fetch(`${API_BASE_URL}/api/v1/protocols`);
        const data = await response.json();
        
        if (data.protocols) {
          setAvailableProtocols(data.protocols);
          if (data.protocols.length > 0) {
            setSelectedProtocolId(data.protocols[0].id);
          }
        }
      } catch (error) {
        console.error('Failed to load protocols:', error);
      } finally {
        setLoadingProtocols(false);
      }
    };

    loadProtocols();
  }, []);

  // Load timeline entries from API
  useEffect(() => {
    const loadTimelineEntries = async () => {
      try {
        const response = await fetch(`${API_BASE_URL}/api/v1/timeline/entries`);
        const data = await response.json();
        
        if (data.entries) {
          setDailyEntries(data.entries);
        }
      } catch (error) {
        console.error('Failed to load timeline entries:', error);
        setDailyEntries([
          { 
            id: 1, 
            entry_time: '07:30', 
            entry_type: 'food', 
            content: 'Chicken, broccoli, avocado', 
            created_at: new Date().toISOString() 
          },
          { 
            id: 2, 
            entry_time: '11:45', 
            entry_type: 'symptom', 
            content: 'Joint Pain', 
            severity: 6, 
            created_at: new Date().toISOString() 
          }
        ]);
      } finally {
        setLoadingEntries(false);
      }
    };

    loadTimelineEntries();
  }, [selectedDate]);

  const selectedProtocol = availableProtocols.find(p => p.id === selectedProtocolId);

  const addEntry = async () => {
    if (newEntry.selectedFoods.length === 0 && !newEntry.customText.trim()) return;
    
    const allItems = [...newEntry.selectedFoods];
    if (newEntry.customText.trim()) {
      allItems.push(newEntry.customText.trim());
    }
    
    const entryData = {
      entryDate: selectedDate,
      entryTime: newEntry.time,
      entryType: newEntry.type,
      content: allItems.join(', '),
      selectedFoods: newEntry.selectedFoods
    };

    try {
      const response = await fetch(`${API_BASE_URL}/api/v1/timeline/entries`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(entryData)
      });

      if (response.ok) {
        const timelineResponse = await fetch(`${API_BASE_URL}/api/v1/timeline/entries`);
        const timelineData = await timelineResponse.json();
        if (timelineData.entries) {
          setDailyEntries(timelineData.entries);
        }
      }
    } catch (error) {
      console.error('Failed to add entry:', error);
    }
    
    setNewEntry({
      time: new Date().toTimeString().slice(0, 5),
      type: 'food',
      selectedItems: [],
      selectedFoods: [],
      customText: '',
      severities: {}
    });
    setShowAddEntry(false);
  };

  const toggleSelectedFood = (food) => {
    const isSelected = newEntry.selectedFoods.includes(food);
    if (isSelected) {
      setNewEntry({
        ...newEntry,
        selectedFoods: newEntry.selectedFoods.filter(f => f !== food)
      });
    } else {
      setNewEntry({
        ...newEntry,
        selectedFoods: [...newEntry.selectedFoods, food]
      });
    }
  };

  const toggleSelectedProtocol = (protocol) => {
    const isSelected = selectedDetoxProtocols.includes(protocol);
    if (isSelected) {
      setSelectedDetoxProtocols(selectedDetoxProtocols.filter(p => p !== protocol));
    } else {
      setSelectedDetoxProtocols([...selectedDetoxProtocols, protocol]);
    }
  };

  const getEntryIcon = (type) => {
    const icons = {
      food: '🍽️',
      symptom: '⚠️',
      supplement: '💊',
      medication: '💉',
      exposure: '☠️',
      note: '📝'
    };
    return icons[type] || '📝';
  };

  const getEntryColor = (type) => {
    const colors = {
      food: 'bg-green-50 border-green-200',
      symptom: 'bg-red-50 border-red-200',
      supplement: 'bg-blue-50 border-blue-200',
      medication: 'bg-purple-50 border-purple-200',
      exposure: 'bg-orange-50 border-orange-200',
      note: 'bg-gray-50 border-gray-200'
    };
    return colors[type] || 'bg-gray-50 border-gray-200';
  };

  return (
    <div className="max-w-md mx-auto bg-white min-h-screen">
      {/* Header */}
      <div className="bg-blue-600 text-white p-4">
        <div className="flex items-center justify-between">
          <h1 className="text-xl font-bold">FILO Health Journal</h1>
          <Calendar size={24} />
        </div>
        <input
          type="date"
          value={selectedDate}
          onChange={(e) => setSelectedDate(e.target.value)}
          className="mt-2 w-full p-2 rounded-lg text-gray-900"
        />
        
        {/* Protocol Selection */}
        {!loadingProtocols && availableProtocols.length > 0 && (
          <div className="mt-3">
            <label className="block text-sm font-medium text-white mb-1">Active Protocol</label>
            <select
              value={selectedProtocolId || ''}
              onChange={(e) => setSelectedProtocolId(e.target.value)}
              className="w-full p-2 rounded-lg text-gray-900 text-sm"
            >
              <option value="">Select Protocol...</option>
              {availableProtocols.map((protocol) => (
                <option key={protocol.id} value={protocol.id}>
                  {protocol.name}
                </option>
              ))}
            </select>
            {selectedProtocol && (
              <p className="text-xs text-blue-100 mt-1">{selectedProtocol.description}</p>
            )}
          </div>
        )}
      </div>

      {/* Navigation */}
      <div className="bg-gray-50 p-4 border-b">
        <div className="flex space-x-4">
          <Button
            variant={activeView === 'timeline' ? 'primary' : 'secondary'}
            onClick={() => setActiveView('timeline')}
          >
            Track
          </Button>
          <Button
            variant={activeView === 'summary' ? 'success' : 'secondary'}
            onClick={() => setActiveView('summary')}
          >
            Reflect
          </Button>
          <div className="relative">
            <Button
              variant={activeView === 'insights' ? 'warning' : 'secondary'}
              onClick={() => setActiveView('insights')}
            >
              Insights
            </Button>
          </div>
        </div>
        
        {/* Protocol Indicator */}
        {selectedProtocol && (
          <div className="mt-2 text-xs text-gray-600">
            Following: <span className="font-medium text-blue-600">{selectedProtocol.name}</span>
          </div>
        )}
      </div>

      {/* Main Content */}
      <div className="p-4">
        {activeView === 'timeline' && (
          <div className="space-y-4">
            {/* Add Entry Button */}
            <Button
              variant="primary"
              size="lg"
              onClick={() => setShowAddEntry(!showAddEntry)}
              icon={Plus}
              className="w-full"
            >
              Add Entry
            </Button>

            {/* Add Entry Form */}
            {showAddEntry && (
              <Card variant="primary" className="space-y-4">
                <div className="flex space-x-3">
                  <div className="flex-1">
                    <label className="block text-sm font-medium text-gray-700 mb-1">Time</label>
                    <input
                      type="time"
                      value={newEntry.time}
                      onChange={(e) => setNewEntry({...newEntry, time: e.target.value})}
                      className="w-full p-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                    />
                  </div>
                  <div className="flex-1">
                    <label className="block text-sm font-medium text-gray-700 mb-1">Type</label>
                    <select
                      value={newEntry.type}
                      onChange={(e) => setNewEntry({...newEntry, type: e.target.value})}
                      className="w-full p-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                    >
                      <option value="food">Food</option>
                      <option value="symptom">Symptom</option>
                      <option value="supplement">Supplement</option>
                      <option value="medication">Medication</option>
                    </select>
                  </div>
                </div>

                <Card>
                  {newEntry.type === 'food' && (
                    <SmartFoodSelector
                      selectedItems={newEntry.selectedFoods}
                      onToggleItem={toggleSelectedFood}
                      selectedProtocol={selectedProtocolId}
                    />
                  )}
                  {newEntry.type !== 'food' && (
                    <div>
                      <label className="block text-sm font-medium text-gray-700 mb-1">Details</label>
                      <input
                        type="text"
                        placeholder={`Enter ${newEntry.type} details...`}
                        value={newEntry.customText}
                        onChange={(e) => setNewEntry({...newEntry, customText: e.target.value})}
                        className="w-full p-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                      />
                    </div>
                  )}
                </Card>

                <div className="flex space-x-2">
                  <Button
                    variant="success"
                    onClick={addEntry}
                    className="flex-1"
                  >
                    Add Entry
                  </Button>
                  <Button
                    variant="secondary"
                    onClick={() => setShowAddEntry(false)}
                    className="flex-1"
                  >
                    Cancel
                  </Button>
                </div>
              </Card>
            )}

            {/* Timeline Entries */}
            <div className="space-y-3">
              <h3 className="font-semibold text-gray-800 flex items-center space-x-2">
                <Clock size={18} />
                <span>Today's Timeline</span>
                {selectedProtocol && (
                  <span className="text-xs bg-blue-100 text-blue-800 px-2 py-1 rounded-full">
                    {selectedProtocol.name}
                  </span>
                )}
              </h3>
              
              {loadingEntries ? (
                <div className="text-center py-8 text-gray-500">
                  <p>Loading timeline entries...</p>
                </div>
              ) : dailyEntries.length > 0 ? (
                dailyEntries.map((entry) => (
                  <div key={entry.id} className={`p-3 rounded-lg border-2 ${getEntryColor(entry.entry_type || entry.type)}`}>
                    <div className="flex items-start justify-between">
                      <div className="flex items-start space-x-3 flex-1">
                        <div className="text-lg">{getEntryIcon(entry.entry_type || entry.type)}</div>
                        <div className="flex-1">
                          <div className="flex items-center space-x-2 mb-2">
                            <span className="font-medium text-sm">{entry.entry_time || entry.time}</span>
                            <span className="text-xs bg-white px-2 py-1 rounded-full capitalize">
                              {entry.entry_type || entry.type}
                            </span>
                            {entry.protocol_compliant === false && (
                              <span className="text-xs bg-red-100 text-red-800 px-2 py-1 rounded-full">
                                ⚠️ Protocol Alert
                              </span>
                            )}
                            {entry.protocol_compliant === true && (
                              <span className="text-xs bg-green-100 text-green-800 px-2 py-1 rounded-full">
                                ✅ Compliant
                              </span>
                            )}
                          </div>
                          <p className="text-sm text-gray-700 mb-2">{entry.content}</p>
                          {entry.severity && (
                            <div className="text-xs text-gray-500">
                              Severity: {entry.severity}/10
                            </div>
                          )}
                        </div>
                      </div>
                    </div>
                  </div>
                ))
              ) : (
                <div className="text-center py-8 text-gray-500">
                  <Clock size={48} className="mx-auto mb-4 text-gray-300" />
                  <p className="text-lg font-medium mb-2">No entries yet today</p>
                  <p className="text-sm">Add your first entry to start tracking!</p>
                </div>
              )}
            </div>
          </div>
        )}

        {activeView === 'insights' && (
          <InsightsTab dailyEntries={dailyEntries} selectedProtocol={selectedProtocol} />
        )}

        {activeView === 'summary' && (
          <div className="space-y-6">
            <div className="flex items-center space-x-2 mb-4">
              <CheckCircle2 size={20} className="text-green-600" />
              <h2 className="text-lg font-semibold">End of Day Reflection</h2>
            </div>

            {/* Sleep & Recovery */}
            <Card variant="primary" title="Sleep & Recovery">
              <div className="space-y-4">
                <div className="grid grid-cols-2 gap-3">
                  <div>
                    <label className="block text-sm font-medium text-gray-700 mb-1">Bedtime</label>
                    <input
                      type="time"
                      className="w-full p-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                    />
                  </div>
                  <div>
                    <label className="block text-sm font-medium text-gray-700 mb-1">Wake Time</label>
                    <input
                      type="time"
                      className="w-full p-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                    />
                  </div>
                </div>
                <div>
                  <label className="block text-sm font-medium text-gray-700 mb-2">Sleep Quality</label>
                  <div className="flex space-x-4">
                    {['Good', 'Okay', 'Poor'].map((quality) => (
                      <label key={quality} className="flex items-center space-x-2">
                        <input
                          type="radio"
                          name="sleepQuality"
                          value={quality.toLowerCase()}
                          className="text-blue-600 focus:ring-blue-500"
                        />
                        <span className="text-sm">{quality}</span>
                      </label>
                    ))}
                  </div>
                </div>
              </div>
            </Card>

            {/* Overall Feeling */}
            <Card variant="warning" title="Overall Feeling - End of Day">
              <div className="space-y-4">
                <div>
                  <label className="block text-sm font-medium text-gray-700 mb-2">
                    Energy Level: 5
                  </label>
                  <input
                    type="range"
                    min="1"
                    max="10"
                    defaultValue="5"
                    className="w-full"
                  />
                </div>
                
                <div>
                  <label className="block text-sm font-medium text-gray-700 mb-1">Overall Notes</label>
                  <textarea
                    placeholder="How are you feeling overall today? Any patterns or insights?"
                    value={overallNotes}
                    onChange={(e) => setOverallNotes(e.target.value)}
                    className="w-full p-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-transparent"
                    rows={2}
                  />
                </div>
              </div>
            </Card>

            {/* Detox Protocols */}
            <Card title="Detox Protocols" variant="purple">
              <div className="space-y-4">
                <SmartProtocolSelector
                  selectedItems={selectedDetoxProtocols}
                  onToggleItem={toggleSelectedProtocol}
                  userProtocols={userDetoxProtocols}
                />
              </div>
            </Card>
          </div>
        )}
      </div>

      {/* Save Button */}
      <div className="p-4 border-t">
        <Button
          variant="success"
          size="lg"
          icon={CheckCircle2}
          className="w-full"
        >
          Save Day
        </Button>
      </div>
    </div>
  );
};

export default EnhancedDailyJournal;
