const InsightsTab = ({ dailyEntries, selectedProtocol }) => {
  const [insights, setInsights] = useState([]);

  useEffect(() => {
    const generateInsights = () => {
      const newInsights = [];
      
      const foodEntries = dailyEntries.filter(entry => 
        (entry.entry_type || entry.type) === 'food'
      );
      
      const nonCompliantEntries = foodEntries.filter(entry => 
        entry.protocol_compliant === false
      );
      
      if (nonCompliantEntries.length > 0) {
        newInsights.push({
          type: 'warning',
          title: 'Protocol Compliance Alert',
          message: `${nonCompliantEntries.length} non-compliant food entries detected. Review your selections to stay on track with your protocol.`,
          critical: true
        });
      }

      const symptoms = dailyEntries.filter(entry => 
        (entry.entry_type || entry.type) === 'symptom'
      );
      
      if (symptoms.length > 1) {
        newInsights.push({
          type: 'info',
          title: 'Symptom Pattern',
          message: `${symptoms.length} symptoms logged today. Consider reviewing recent food choices for potential triggers.`,
          critical: false
        });
      }

      if (selectedProtocol) {
        newInsights.push({
          type: 'info',
          title: `${selectedProtocol.name} Progress`,
          message: `Following ${selectedProtocol.name}. ${selectedProtocol.description}`,
          critical: false
        });
      }

      const compliantEntries = foodEntries.filter(entry => 
        entry.protocol_compliant === true
      );
      
      if (compliantEntries.length > 0 && nonCompliantEntries.length === 0) {
        newInsights.push({
          type: 'success',
          title: 'Great Protocol Compliance!',
          message: `All ${compliantEntries.length} food entries today were protocol-compliant. Keep up the excellent work!`,
          critical: false
        });
      }

      setInsights(newInsights);
    };

    generateInsights();
  }, [dailyEntries, selectedProtocol]);

  return (
    <div className="space-y-6">
      <Card title="Health Dashboard" icon={TrendingUp} variant="primary">
        <div className="grid grid-cols-2 gap-4">
          <div className="text-center">
            <div className="text-2xl font-bold text-green-600">
              {selectedProtocol ? '100%' : '--'}
            </div>
            <div className="text-sm text-gray-600">Protocol Setup</div>
          </div>
          <div className="text-center">
            <div className="text-2xl font-bold text-blue-600">{dailyEntries.length}</div>
            <div className="text-sm text-gray-600">Entries Today</div>
          </div>
        </div>
        {selectedProtocol && (
          <div className="mt-3 text-xs text-gray-600">
            Active Protocol: <span className="font-medium text-blue-600">{selectedProtocol.name}</span>
          </div>
        )}
      </Card>

      {insights.filter(insight => insight.critical).length > 0 && (
        <Card title="Critical Insights" variant="warning">
          <div className="space-y-3">
            {insights.filter(insight => insight.critical).map((insight, index) => (
              <Alert key={index} variant={insight.type} title={insight.title}>
                {insight.message}
              </Alert>
            ))}
          </div>
        </Card>
      )}

      {insights.filter(insight => !insight.critical).length > 0 && (
        <Card title="Daily Insights" icon={Info}>
          <div className="space-y-3">
            {insights.filter(insight => !insight.critical).map((insight, index) => (
              <Alert key={index} variant={insight.type} title={insight.title}>
                {insight.message}
              </Alert>
            ))}
          </div>
        </Card>
      )}

      {selectedProtocol && (
        <Card title="Protocol Information" variant="primary">
          <div className="space-y-2">
            <div>
              <span className="font-medium">Name:</span> {selectedProtocol.name}
            </div>
            <div>
              <span className="font-medium">Description:</span> {selectedProtocol.description}
            </div>
            {selectedProtocol.category && (
              <div>
                <span className="font-medium">Category:</span> {selectedProtocol.category}
              </div>
            )}
            <div className="text-xs text-gray-500 mt-2">
              This protocol guidance is loaded dynamically from our database and can be updated by practitioners.
            </div>
          </div>
        </Card>
      )}

      {!selectedProtocol && (
        <Card title="Get Started" variant="warning">
          <div className="text-center py-4">
            <p className="text-sm text-gray-600 mb-3">
              Select a protocol above to receive personalized food recommendations and compliance tracking.
            </p>
            <div className="text-xs text-gray-500">
              Our database contains multiple protocols including AIP, GAPS, Carnivore, and more.
            </div>
          </div>
        </Card>
      )}

      {insights.length === 0 && (
        <Card>
          <div className="text-center py-8 text-gray-500">
            <TrendingUp size={48} className="mx-auto mb-4 text-gray-300" />
            <p className="text-lg font-medium mb-2">Start tracking to see insights</p>
            <p className="text-sm">Add food entries and symptoms to generate personalized insights!</p>
          </div>
        </Card>
      )}
    </div>
  );
};

