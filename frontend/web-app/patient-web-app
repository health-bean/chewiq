const SmartFoodSelector = ({ selectedItems, onToggleItem, selectedProtocol = null }) => {
  const [searchTerm, setSearchTerm] = useState('');
  const [foods, setFoods] = useState([]);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState(null);

  useEffect(() => {
    const loadFoods = async () => {
      if (!searchTerm.trim()) {
        setFoods([]);
        return;
      }

      setLoading(true);
      setError(null);

      try {
        let url = `${API_BASE_URL}/api/v1/foods/search?search=${encodeURIComponent(searchTerm)}`;
        if (selectedProtocol) {
          url += `&protocol_id=${selectedProtocol}`;
        }

        const response = await fetch(url);
        const data = await response.json();
        
        if (data.foods) {
          setFoods(data.foods);
        } else {
          setError('No foods found');
        }
      } catch (err) {
        console.error('Failed to load foods:', err);
        setError('Failed to load foods');
      } finally {
        setLoading(false);
      }
    };

    const timer = setTimeout(loadFoods, 300);
    return () => clearTimeout(timer);
  }, [searchTerm, selectedProtocol]);

  return (
    <div className="space-y-4">
      <div className="relative">
        <Search size={16} className="absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400" />
        <input
          type="text"
          placeholder="Start typing to search foods..."
          value={searchTerm}
          onChange={(e) => setSearchTerm(e.target.value)}
          className="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
        />
      </div>

      {loading && (
        <div className="text-center py-4">
          <div className="text-sm text-gray-500">Searching foods...</div>
        </div>
      )}

      {error && (
        <div className="text-center py-4">
          <div className="text-sm text-red-500">{error}</div>
        </div>
      )}

      <div className="max-h-64 overflow-y-auto space-y-2">
        {foods.map((food) => {
          const isSelected = selectedItems.includes(food.name);
          
          return (
            <div key={food.id} className="space-y-2">
              <div className={`p-3 border rounded-lg cursor-pointer transition-all ${
                isSelected 
                  ? 'border-blue-500 bg-blue-50' 
                  : 'border-gray-200 hover:border-gray-300'
              }`} onClick={() => onToggleItem(food.name)}>
                <div className="flex items-start justify-between">
                  <div className="flex-1">
                    <div className="flex items-center space-x-2 mb-1">
                      <input
                        type="checkbox"
                        checked={isSelected}
                        onChange={() => onToggleItem(food.name)}
                        className="rounded text-blue-600 focus:ring-blue-500"
                      />
                      <span className="font-medium capitalize">{food.name}</span>
                      {food.protocol_status && (
                        <ProtocolStatusBadge status={food.protocol_status} />
                      )}
                    </div>
                    
                    <p className="text-sm text-gray-600 mb-2 capitalize">{food.category} source</p>
                    
                    <div className="flex flex-wrap gap-1">
                      <PropertyBadge property="nightshade" level={food.nightshade} />
                      <PropertyBadge property="histamine" level={food.histamine} />
                      <PropertyBadge property="oxalate" level={food.oxalate} />
                      <PropertyBadge property="lectin" level={food.lectin} />
                    </div>
                  </div>
                </div>
              </div>
              
              {isSelected && food.protocol_status === 'avoid' && (
                <Alert variant="danger">
                  {food.name} is not allowed on your current protocol
                </Alert>
              )}
            </div>
          );
        })}
      </div>

      {searchTerm && !loading && foods.length === 0 && !error && (
        <div className="text-center py-8 text-gray-500">
          <p>No foods found matching "{searchTerm}"</p>
          <p className="text-sm">Try a different search term</p>
        </div>
      )}
    </div>
  );
};

