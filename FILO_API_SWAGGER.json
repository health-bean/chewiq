{
  "openapi": "3.0.0",
  "info": {
    "title": "FILO Health Platform API",
    "version": "1.0.0",
    "description": "Protocol Management & Healing Platform API",
    "contact": {
      "name": "FILO Health Platform"
    }
  },
  "servers": [
    {
      "url": "https://suhoxvn8ik.execute-api.us-east-1.amazonaws.com/dev",
      "description": "Production server"
    }
  ],
  "paths": {
    "/api/v1/protocols": {
      "get": {
        "summary": "Get available health protocols",
        "description": "Get available health protocols. Response time: 1464ms",
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "protocols": {
                      "type": "array"
                    },
                    "total": {
                      "type": "number"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/timeline/entries": {
      "get": {
        "summary": "Get timeline entries with date filter",
        "description": "Get timeline entries with date filter. Response time: 52ms",
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "entries": {
                      "type": "array"
                    },
                    "total": {
                      "type": "number"
                    }
                  }
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "date",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "2025-06-29"
          }
        ]
      }
    }
  }
}